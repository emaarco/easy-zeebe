          <dc:Bounds x="417" y="275" width="67" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SubProcess_confirm_di" bpmnElement="subProcess_ConfirmMembership" isExpanded="true">
